% define definition, theorem, lemma, statement, proff, proved

\def\@thrmcontext{}
\@ifundefined{thrmcontext}{}{\def\@thrmcontext{[\thrmcontext]}}

\newtheorem{definition}{Определение}
\newtheorem{@statement}{Утверждение}
\newtheorem{@lemma}{Лемма}
\newtheorem{@theorem}{Теорема}

\def\@thrmcurrent{@thrmnone}
\def\@thrmsetlabel[#1]{\label{#1}}
\def\@thrmbegin#1{
  \@ifundefined{\@thrmcurrent}
    {\gdef\@thrmcurrent{#1}\gdef\@thrmend{\end{#1}}}
    {\@warning{Nested theorems at page \thepage}}
  \begin{#1}
  \@ifnextchar[{\@thrmsetlabel}{}
}

\def\definition{\@thrmbegin{@definition}}
\def\endefinition{\end{\@definition}}

\def\statement{\@thrmbegin{@statement}}
\def\lemma{\@thrmbegin{@lemma}}
\def\theorem{\@thrmbegin{@theorem}}


