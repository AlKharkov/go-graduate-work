 {6pt}{\large\bf}}
\def\section{\@ifstar{\@xsections}{\@xsection}}
\def\@xsections#1{\@@section*{#1}}
\def\@xsection#1{\@@section{{#1}}}

% Title shall be in upper case
\def\title#1{\gdef\@title{{\Large\bf #1}}}

