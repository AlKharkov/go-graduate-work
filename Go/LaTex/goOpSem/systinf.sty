\long\def\@caption#1[#2]#3{\par\addcontentsline{\csname
  ext@#1\endcsname}{#1}{\protect\numberline{\csname
  the#1\endcsname}{\ignorespaces #2}}\begingroup
    \@parboxrestore \newcommand{\ty}{\csname ftype@\@captype\endcsname}
    \normalsize\ifnum\ty=2
    \@makecaptiontab{\csname fnum@#1\endcsname}{\ignorespaces #3}\par
     \else
    \@makecaptionfig{\csname fnum@#1\endcsname}{\ignorespaces #3}\par
     \fi
  \endgroup}


\long\def\@makecaptionfig#1#2{
 \vskip 10pt
 \small
 \centering
 \setbox\@tempboxa\hbox{{\it #1.} #2}
 \ifdim \wd\@tempboxa >\hsize {\it #1. #2}\par \else \hbox
to\hsize{\hfil\box\@tempboxa\hfil}
 \vspace{-4pt}
 \fi\normalsize\rm}

\long\def\@makecaptiontab#1#2{
 \vskip 6pt\small
 \hbox to\hsize{\hfill\ #1}\par
\vskip 10pt
\hbox to \hsize{\hfill\bf #2\hfill}
 \vspace{6pt}}




